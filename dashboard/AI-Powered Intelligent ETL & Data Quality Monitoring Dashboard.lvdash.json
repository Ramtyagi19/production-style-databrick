                    },
                    {
                      "name": "invalid_rows",
                      "expression": "`invalid_rows`"
                    },
                    {
                      "name": "invalid_ratio",
                      "expression": "`invalid_ratio`"
                    }
                  ],
                  "disaggregated": true
                }
              }
            ],
            "spec": {
              "version": 2,
              "frame": {
                "title": "AI Agent Decisions",
                "showTitle": true
              },
              "widgetType": "table",
              "encodings": {
                "columns": [
                  {
                    "fieldName": "actions"
                  },
                  {
                    "fieldName": "total_rows"
                  },
                  {
                    "fieldName": "invalid_rows"
                  },
                  {
                    "fieldName": "invalid_ratio"
                  }
                ]
              }
            }
          },
          "position": {
            "x": 8,
            "y": 13,
            "width": 4,
            "height": 6
          }
        }
